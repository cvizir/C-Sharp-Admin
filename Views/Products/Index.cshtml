@model IEnumerable<ProductManager.Models.Product>

<h2>產品管理</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">新增產品</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>產品圖片</th>
            <th>@Html.DisplayNameFor(model => model.ProductCode)</th>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Price)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @if (item.Images != null && item.Images.Any())
                {
                    <img src="@item.Images.First().ImagePath" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" />
                    @if (item.Images.Count > 1)
                    {
                        <span class="badge bg-secondary">+@(item.Images.Count - 1)</span>
                    }
                }
                else
                {
                    <span class="text-muted">無圖片</span>
                }
            </td>
            <td>@item.ProductCode</td>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>@item.Description</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">編輯</a>
                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('確定要刪除嗎？');">刪除</button>
                </form>
            </td>
        </tr>
}
    </tbody>
</table>